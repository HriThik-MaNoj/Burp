# рҹ§° Install Dependencies (Java, figlet, lolcat)
install_dependencies() {
    echo "рҹ”§ Checking & Installing Dependencies..."

    if ! command -v java &> /dev/null; then
        echo "вҸі Java not found. Installing OpenJDK..."
        sudo apt update
        sudo apt install -y default-jdk
    else
        echo "вң” Java is already installed."
    fi

    if ! command -v figlet &> /dev/null; then
        echo "вҸі Installing figlet..."
        sudo apt install -y figlet
    fi

    if ! command -v lolcat &> /dev/null; then
        echo "вҸі Installing lolcat..."
        sudo apt install -y lolcat
    fi

    echo "вң… All dependencies installed."
    echo ""
}

# рҹҺЁ Show Banner
show_banner() {
    clear
    figlet "Hri7h!k Launcher" | lolcat
    echo ""
}

# рҹ“Ғ Prompt for JAR File
prompt_for_path() {
    local prompt_message=$1
    local default_file=$2
    read -p "$prompt_message [Press Enter to use './$default_file']: " input_path
    if [[ -z "$input_path" ]]; then
        input_path="./$default_file"
    fi
    if [[ ! -f "$input_path" ]]; then
        echo "вқҢ Error: File '$input_path' not found!"
        exit 1
    fi
    echo "$(realpath "$input_path")"
}

# вң… Main Execution
install_dependencies
show_banner

SDKMAN_JAVA="$HOME/.sdkman/candidates/java/current/bin/java"
SYS_JAVA="/usr/lib/jvm/java-21-openjdk-amd64/bin/java"

if [[ -f "$SDKMAN_JAVA" ]]; then
    JAVA_BIN="$SDKMAN_JAVA"
elif [[ -f "$SYS_JAVA" ]]; then
    JAVA_BIN="$SYS_JAVA"
else
    echo "вқҢ Java 21+ not found. Install via: sdk install java 21.0.7-tem"
    exit 1
fi
echo "вң” Java found at: $JAVA_BIN"
echo ""

AGENT_JAR=$(prompt_for_path "Enter location for the Loader JAR file" "loader.jar")
echo ""

# рҹҡҖ Run Java with Agent
echo "рҹҡҖ Launching BurpSuite with Loader agent..."
export _JAVA_AWT_WM_NONREPARENTING=1
wmname LG3D 2>/dev/null
"$JAVA_BIN" \
    --add-opens=java.desktop/javax.swing=ALL-UNNAMED \
    --add-opens=java.base/java.lang=ALL-UNNAMED \
    --add-opens=java.base/jdk.internal.org.objectweb.asm=ALL-UNNAMED \
    --add-opens=java.base/jdk.internal.org.objectweb.asm.tree=ALL-UNNAMED \
    --add-opens=java.base/jdk.internal.org.objectweb.asm.Opcodes=ALL-UNNAMED \
    -Dsun.java2d.opengl=false \
    -Dsun.java2d.xrender=false \
    -Dsun.java2d.pmoffscreen=false \
    -Dawt.useSystemAAFontSettings=on \
    -XX:+EnableDynamicAgentLoading \
    -javaagent:"$AGENT_JAR" \
    -jar "$AGENT_JAR"
